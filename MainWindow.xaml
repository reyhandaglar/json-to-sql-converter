<Window x:Class="NoSQLtoSQL.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NoSQL → SQL Dönüşüm Sistemi" Height="850" Width="1200"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen">

	<Window.Resources>
		<Style TargetType="TreeViewItem">
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="FontSize" Value="13"/>
			<Setter Property="Background" Value="Transparent"/>
		</Style>
	</Window.Resources>

	<Grid Background="#1e1e2e">
		<Grid.RowDefinitions>
			<RowDefinition Height="60"/>
			<RowDefinition Height="60"/>
			<RowDefinition Height="2*" MinHeight="150"/>
			<RowDefinition Height="*"  MinHeight="100"/>
			<RowDefinition Height="*"  MinHeight="80"/>
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="350" MinWidth="200"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<!-- Üst Bar -->
		<Border Grid.Row="0" Grid.ColumnSpan="2" Background="#313244">
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
				<TextBlock Text="NoSQL → SQL Dönüşüm Sistemi" Foreground="White"
                           FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
				<Button x:Name="btnDosyaSec" Content="📂 JSON Dosyası Seç"
                        Margin="30,0,10,0" Padding="15,8" Background="#89b4fa"
                        Foreground="#1e1e2e" FontWeight="Bold" BorderThickness="0"
                        Cursor="Hand" Click="btnDosyaSec_Click"/>
				<Button x:Name="btnDonustur" Content="⚡ Dönüştür"
                        Margin="10,0" Padding="15,8" Background="#a6e3a1"
                        Foreground="#1e1e2e" FontWeight="Bold" BorderThickness="0"
                        Cursor="Hand" Click="btnDonustur_Click" IsEnabled="False"/>
				<Button x:Name="btnSifirla" Content="🗑️ Sıfırla"
                        Margin="10,0" Padding="15,8" Background="#f38ba8"
                        Foreground="#1e1e2e" FontWeight="Bold" BorderThickness="0"
                        Cursor="Hand" Click="btnSifirla_Click"/>
			</StackPanel>
		</Border>

		<!-- İstatistik Paneli -->
		<Border Grid.Row="1" Grid.ColumnSpan="2" Background="#252535" Margin="10,5,10,0" CornerRadius="8">
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="15,0">
				<TextBlock Text="📊 İstatistikler:" Foreground="#cdd6f4" FontWeight="Bold"
                           FontSize="13" VerticalAlignment="Center" Margin="0,0,20,0"/>
				<Border Background="#313244" CornerRadius="6" Padding="12,5" Margin="0,0,10,0">
					<StackPanel Orientation="Horizontal">
						<TextBlock Text="🗂️ Tablo: " Foreground="#89b4fa" FontSize="12"/>
						<TextBlock x:Name="txtStatTablo" Text="0" Foreground="White" FontSize="12" FontWeight="Bold"/>
					</StackPanel>
				</Border>
				<Border Background="#313244" CornerRadius="6" Padding="12,5" Margin="0,0,10,0">
					<StackPanel Orientation="Horizontal">
						<TextBlock Text="📝 Kayıt: " Foreground="#a6e3a1" FontSize="12"/>
						<TextBlock x:Name="txtStatKayit" Text="0" Foreground="White" FontSize="12" FontWeight="Bold"/>
					</StackPanel>
				</Border>
				<Border Background="#313244" CornerRadius="6" Padding="12,5" Margin="0,0,10,0">
					<StackPanel Orientation="Horizontal">
						<TextBlock Text="🔗 FK: " Foreground="#fab387" FontSize="12"/>
						<TextBlock x:Name="txtStatFK" Text="0" Foreground="White" FontSize="12" FontWeight="Bold"/>
					</StackPanel>
				</Border>
				<Border Background="#313244" CornerRadius="6" Padding="12,5" Margin="0,0,10,0">
					<StackPanel Orientation="Horizontal">
						<TextBlock Text="⏱️ Süre: " Foreground="#f9e2af" FontSize="12"/>
						<TextBlock x:Name="txtStatSure" Text="0 ms" Foreground="White" FontSize="12" FontWeight="Bold"/>
					</StackPanel>
				</Border>
				<Border Background="#313244" CornerRadius="6" Padding="12,5" Margin="0,0,10,0">
					<StackPanel Orientation="Horizontal">
						<TextBlock Text="📄 JSON Boyutu: " Foreground="#cba6f7" FontSize="12"/>
						<TextBlock x:Name="txtStatBoyut" Text="-" Foreground="White" FontSize="12" FontWeight="Bold"/>
					</StackPanel>
				</Border>
			</StackPanel>
		</Border>

		<!-- Sol Panel: JSON Ağaç Görünümü -->
		<Border Grid.Row="2" Grid.Column="0" Background="#181825" Margin="10,8,5,5" CornerRadius="8">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="35"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>
				<TextBlock Grid.Row="0" Text="📋 JSON Yapısı" Foreground="White"
                           FontWeight="Bold" FontSize="13" Margin="10,8"/>
				<TreeView x:Name="treeJson" Grid.Row="1" Background="#181825"
                          BorderThickness="0" Margin="5">
					<TreeView.Resources>
						<SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#444466"/>
						<SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
						<SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#333355"/>
						<SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>
						<SolidColorBrush x:Key="{x:Static SystemColors.HotTrackBrushKey}" Color="#444466"/>
						<SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#181825"/>
					</TreeView.Resources>
				</TreeView>
			</Grid>
		</Border>

		<!-- Sağ Panel: Tablo Seçici + DataGrid -->
		<Border Grid.Row="2" Grid.Column="1" Background="#181825" Margin="5,8,10,5" CornerRadius="8">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="40"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>
				<StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
					<TextBlock Text="📊 Tablo:" Foreground="White" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
					<ComboBox x:Name="cmbTablolar" Width="200"
                              SelectionChanged="cmbTablolar_SelectionChanged"/>
				</StackPanel>
				<DataGrid x:Name="dataGrid" Grid.Row="1" Background="Transparent"
                          Foreground="White" BorderThickness="0" Margin="5"
                          AutoGenerateColumns="True" IsReadOnly="True"
                          RowBackground="#1e1e2e" AlternatingRowBackground="#181825"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#313244">
					<DataGrid.ColumnHeaderStyle>
						<Style TargetType="DataGridColumnHeader">
							<Setter Property="Background" Value="#313244"/>
							<Setter Property="Foreground" Value="White"/>
							<Setter Property="FontWeight" Value="Bold"/>
							<Setter Property="Padding" Value="8,5"/>
							<Setter Property="BorderBrush" Value="#444466"/>
							<Setter Property="BorderThickness" Value="0,0,1,1"/>
						</Style>
					</DataGrid.ColumnHeaderStyle>
				</DataGrid>
			</Grid>
		</Border>

		<!-- SQL Sorgu Paneli -->
		<Border Grid.Row="3" Grid.ColumnSpan="2" Background="#181825" Margin="10,5,10,5" CornerRadius="8">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="30"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="120"/>
				</Grid.ColumnDefinitions>
				<TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="🔍 SQL Sorgu Ekranı"
                           Foreground="White" FontWeight="Bold" FontSize="13" Margin="10,5"/>
				<TextBox x:Name="txtSorgu" Grid.Row="1" Grid.Column="0"
                         Background="#1e1e2e" Foreground="#a6e3a1"
                         BorderThickness="1" BorderBrush="#444466"
                         FontFamily="Consolas" FontSize="13"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         Margin="8,4,4,8" Padding="8"
                         Text="SELECT * FROM "
                         VerticalScrollBarVisibility="Auto"/>
				<StackPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" Margin="4,0,8,0">
					<Button x:Name="btnSorguCalistir" Content="▶ Çalıştır"
                            Padding="10,8" Background="#89b4fa"
                            Foreground="#1e1e2e" FontWeight="Bold" BorderThickness="0"
                            Cursor="Hand" Click="btnSorguCalistir_Click" Margin="0,0,0,6"/>
					<Button x:Name="btnSorguTemizle" Content="✖ Temizle"
                            Padding="10,8" Background="#585b70"
                            Foreground="White" FontWeight="Bold" BorderThickness="0"
                            Cursor="Hand" Click="btnSorguTemizle_Click"/>
				</StackPanel>
			</Grid>
		</Border>

		<!-- Alt Panel: Log -->
		<Border Grid.Row="4" Grid.ColumnSpan="2" Background="#181825" Margin="10,5,10,10" CornerRadius="8">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="30"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>
				<TextBlock Grid.Row="0" Text="📝 İşlem Günlüğü" Foreground="White"
                           FontWeight="Bold" FontSize="13" Margin="10,5"/>
				<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
					<TextBox x:Name="txtLog" Background="Transparent" Foreground="#a6e3a1"
                             BorderThickness="0" IsReadOnly="True" TextWrapping="Wrap"
                             FontFamily="Consolas" FontSize="12" Margin="10,0"/>
				</ScrollViewer>
			</Grid>
		</Border>
	</Grid>
</Window>